	assert_true(ai_config.has("away_seconds"), "Tenant AI config should include away duration")
	assert_true(ai_config.has("return_stagger_seconds"), "Tenant AI config should include return stagger duration")
	assert_true(ai_config.has("route_speed"), "Tenant AI config should include route speed")
	assert_false(ai_config.has("entry_from_offscreen"), "Tenant AI config should not include startup offscreen entry toggling")
	assert_true(ai_config.has("door_animation_seconds"), "Tenant AI config should include door animation wait")
	assert_true(ai_config.has("door_open_idle_seconds"), "Tenant AI config should include open-door idle timing")
	assert_true(ai_config.has("elevator_animation_seconds"), "Tenant AI config should include elevator animation wait")
	assert_true(ai_config.has("elevator_idle_seconds"), "Tenant AI config should include elevator open idle timing")
	assert_true(ai_config.has("elevator_open_show_progress"), "Tenant AI config should include target elevator show progress")
	assert_true(ai_config.has("elevator_close_hide_progress"), "Tenant AI config should include source elevator hide progress")
	assert_true(ai_config.has("offscreen_margin"), "Tenant AI config should include offscreen route margin")
	assert_eq(float(ai_config.get("door_animation_seconds", 0.0)), 0.24, "Tenant doors should use the readable configured open/close duration")
	assert_eq(float(ai_config.get("door_open_idle_seconds", 0.0)), 0.12, "Tenant doors should wait briefly only after opening")
	assert_eq(float(ai_config.get("elevator_animation_seconds", 0.0)), 0.56, "Five-frame elevator doors should play near their natural duration")
	assert_eq(float(ai_config.get("elevator_idle_seconds", 0.0)), 0.25, "Elevators should wait briefly while fully open")
	assert_eq(float(ai_config.get("elevator_open_show_progress", 0.0)), 0.75, "Returning tenants should appear before the elevator is fully open")
	assert_eq(float(ai_config.get("elevator_close_hide_progress", 0.0)), 0.85, "Leaving tenants should disappear before the elevator is fully closed")
	assert_eq(float(ai_config.get("return_stagger_seconds", 0.0)), 4.0, "Tenants should stagger their return starts so they do not overlap perfectly")
	assert_eq(float(ai_config.get("offscreen_margin", 0.0)), 64.0, "Tenant offscreen route mark should sit well outside the visible left edge")
	assert_true(ai_source.contains("_staggered_away_until(away_seconds)"), "Leaving tenants should save staggered return timestamps")
	assert_true(ai_source.contains("func _return_start_delay_seconds"), "Returning tenants restored from save should stagger route start times")
	assert_true(ai_source.contains("func _tenant_return_order_index"), "Return staggering should be stable per tenant id")

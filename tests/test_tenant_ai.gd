	assert_true(game_state_source.contains("\"away_until_timestamp\": 0"), "New tenant saves should default away timestamp")
	assert_true(game_state_source.contains("\"presence_target_room_id\": \"\""), "New tenant saves should reserve target room routing")
	assert_true(game_state_source.contains("func set_tenant_presence"), "GameState should expose presence syncing")
	assert_false(game_state_source.contains("save_needs_writeback"), "Presence state should use the current save schema without migration writeback flags")

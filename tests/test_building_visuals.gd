func test_apartment_tilemap_renders_room_frame_tiles_on_16px_grid() -> void:
	var tilemap_script := ResourceLoader.load("res://scripts/building/ApartmentTileMap.gd", "Script", ResourceLoader.CACHE_MODE_IGNORE) as Script
	var scene := ResourceLoader.load("res://scenes/building/ApartmentTileMap.tscn", "PackedScene", ResourceLoader.CACHE_MODE_REPLACE) as PackedScene
	assert_true(scene != null, "ApartmentTileMap scene should load for direct preview")
	if scene == null:
		return
	var tilemap := scene.instantiate() as ApartmentTileMap
	assert_true(tilemap != null, "ApartmentTileMap scene should instantiate with its script")
	if tilemap == null:
		return
	assert_true(tilemap_script != null, "ApartmentTileMap test should reload the current script from disk")
	if tilemap_script != null:
		tilemap.set_script(tilemap_script)
	_bind_apartment_tilemap_layers(tilemap)
	var wallpaper_layer := tilemap.get_node("WallpaperTileMap") as TileMapLayer
	var wall_layer := tilemap.get_node("WallTileMap") as TileMapLayer
	var infrastructure_layer := tilemap.get_node("InfrastructureTileMap") as TileMapLayer

	tilemap.render_room_skeleton(Vector2i(6, 4), {}, false, false)
	assert_eq(tilemap.get("current_frame_tiles"), Vector2i(6, 4), "Initial room frame should be 6x4 tiles")
	assert_eq(tilemap.room_pixel_size(), Vector2(96, 64), "6x4 frame tiles should render as 96x64 pixels")
	assert_eq(wallpaper_layer.get_used_rect().position, Vector2i.ZERO, "Wallpaper should start at tile origin")
	assert_eq(wallpaper_layer.get_used_rect().size, Vector2i(6, 4), "Wallpaper layer should cover every room tile")
	assert_eq(wall_layer.get_used_rect().position, Vector2i.ZERO, "Room frame should start at tile origin")
	assert_eq(wall_layer.get_used_rect().size, Vector2i(6, 4), "Wall layer should occupy a 6x4 tile frame")
	assert_eq(infrastructure_layer.get_used_rect().position, Vector2i(-1, -1), "Infrastructure black wall edge should wrap one tile around the room frame")
	assert_eq(infrastructure_layer.get_used_rect().size, Vector2i(8, 6), "Infrastructure layer should include the outer black wall edge")
	assert_eq(infrastructure_layer.get_cell_source_id(Vector2i(0, 2)), -1, "ApartmentTileMap should not paint the old room door placeholder")
	var room_long_left_tiles: Array = tilemap.get("body_left_edge_tiles")
	var room_short_left_tiles: Array = tilemap.get("body_left_door_edge_tiles")
	var room_short_right_tiles: Array = tilemap.get("body_right_door_edge_tiles")
	assert_eq(wall_layer.get_cell_atlas_coords(Vector2i(0, 0)), tilemap.get("body_top_left_corner_tile"), "Room left wall with a door should start with the top-left corner")
	assert_eq(wall_layer.get_cell_atlas_coords(Vector2i(0, 1)), room_long_left_tiles[0], "Room left wall with a door should keep a long edge below the corner")
	assert_eq(wall_layer.get_cell_atlas_coords(Vector2i(0, 2)), room_short_left_tiles[0], "Room left wall with a door should use the short edge immediately above the door")
	var room_bottom_tiles: Array = tilemap.get("body_bottom_edge_tiles")
	assert_eq(wall_layer.get_cell_atlas_coords(Vector2i(0, 3)), room_bottom_tiles[0], "Room left wall with a door should use a bottom edge below the door")
	assert_eq(infrastructure_layer.get_cell_atlas_coords(Vector2i(5, 1)), Vector2i(5, 2), "Room window should use the configured right-wall tile")

	tilemap.render_room_skeleton(Vector2i(6, 4), {}, false, false, {"left": true, "right": false, "top": false, "bottom": false}, {}, "right")
	assert_eq(tilemap.get("current_door_side"), "right", "01 rooms should render a right-wall door cutout")
	assert_eq(tilemap.get("current_has_left_door"), false, "Right-wall-door rooms should not report a left door")
	assert_eq(tilemap.get("current_has_right_door"), true, "Right-wall-door rooms should report a right door")
	assert_eq(wall_layer.get_cell_atlas_coords(Vector2i(5, 0)), tilemap.get("body_top_right_corner_tile"), "Room right wall with a door should start with the top-right corner")
	assert_eq(wall_layer.get_cell_atlas_coords(Vector2i(5, 1)), tilemap.get("body_right_edge_tiles")[0], "Room right wall with a door should keep a long edge below the corner")
	assert_eq(wall_layer.get_cell_atlas_coords(Vector2i(5, 2)), room_short_right_tiles[0], "Right-wall door should use the right-side short door wall tile")
	assert_eq(wall_layer.get_cell_atlas_coords(Vector2i(5, 3)), room_bottom_tiles[0], "Right-wall door should use the bottom edge below the door")
	assert_eq(infrastructure_layer.get_cell_source_id(Vector2i(5, 1)), -1, "Right-wall doors should suppress the regular right-wall window")

	var left_edge_theme := {
		"edge_left_edge_tiles": [Vector2i(0, 3)],
		"edge_left_door_edge_tiles": [Vector2i(4, 1)]
	}
	tilemap.render_room_skeleton(Vector2i(3, 4), left_edge_theme, false, false, {"left": true, "right": false, "top": false, "bottom": false}, {"left": true, "right": false, "top": true, "bottom": true}, "left")
	assert_eq(infrastructure_layer.get_cell_atlas_coords(Vector2i(-1, 1)), Vector2i(0, 3), "Door service black edge should keep a long edge below the corner")
	assert_eq(infrastructure_layer.get_cell_atlas_coords(Vector2i(-1, 2)), Vector2i(4, 1), "Door service black edge should use edge_left_door_edge_tiles immediately above the door")

	tilemap.render_room_skeleton(Vector2i(3, 4), left_edge_theme, false, false, {"left": true, "right": false, "top": false, "bottom": false}, {"left": true, "right": false, "top": true, "bottom": true}, "")
	assert_eq(infrastructure_layer.get_cell_atlas_coords(Vector2i(-1, 2)), Vector2i(0, 3), "Closed service black edge should not use the door-short black edge tile")

	tilemap.render_room_skeleton(Vector2i(8, 4), {}, false, false)
	assert_eq(tilemap.get("current_frame_tiles"), Vector2i(8, 4), "Room expansion should only add width tiles")
	assert_eq(tilemap.room_pixel_size(), Vector2(128, 64), "8x4 frame tiles should render as 128x64 pixels")
	assert_eq(wallpaper_layer.get_used_rect().size, Vector2i(8, 4), "Expanded wallpaper layer should cover every room tile")
	assert_eq(wall_layer.get_used_rect().size, Vector2i(8, 4), "Expanded wall layer should keep fixed height")
	assert_eq(infrastructure_layer.get_used_rect().size, Vector2i(10, 6), "Expanded infrastructure layer should keep the one-tile outer wall edge")
	assert_eq(infrastructure_layer.get_cell_atlas_coords(Vector2i(7, 1)), Vector2i(5, 2), "Expanded room window should move with the right wall")

	tilemap.render_room_skeleton(Vector2i(3, 4), {}, false, false)
	assert_eq(tilemap.get("current_frame_tiles"), Vector2i(3, 4), "Service-core TileMaps should support 3-tile width")
	assert_eq(tilemap.room_pixel_size(), Vector2(48, 64), "3x4 service core should render as 48x64 pixels")
	assert_eq(wall_layer.get_used_rect().size, Vector2i(3, 4), "Service-core frame should not overpaint into the room")

	tilemap.render_room_skeleton(Vector2i(3, 4), {}, false, false, {"left": false, "right": false, "top": false, "bottom": false}, {"left": false, "right": false, "top": true, "bottom": true}, "")
	assert_eq(tilemap.get("current_body_sides").get("left", true), false, "Central elevator service should disable the left body side")
	assert_eq(tilemap.get("current_body_sides").get("right", true), false, "Service-core test should disable the right body side")
	assert_eq(tilemap.get("current_has_left_door"), false, "Central elevator service should render without a left exit-door cutout")
	assert_eq(tilemap.call("_body_side_enabled", "right"), false, "Service-core right body side helper should read the disabled side")
	var service_bottom_tiles: Array = tilemap.get("body_bottom_edge_tiles")
	assert_eq(tilemap.call("_body_tile_at", 2, 0, 2, 3), Vector2i(3, 17), "Open service top-right should resolve to the horizontal top edge tile")
	assert_eq(tilemap.call("_body_tile_at", 0, 3, 2, 3), service_bottom_tiles[0], "Open service bottom-left should resolve to the horizontal bottom edge tile")
	assert_eq(wall_layer.get_cell_source_id(Vector2i(0, 1)), -1, "Central service should not draw a left body wall next to the left room")
	assert_eq(wall_layer.get_cell_source_id(Vector2i(2, 1)), -1, "Central service should not draw a right body wall next to the right room")
	for x in range(3):
		assert_false(wall_layer.get_cell_source_id(Vector2i(x, 0)) == -1, "Service core should keep its top body edge")
		assert_false(wall_layer.get_cell_source_id(Vector2i(x, 3)) == -1, "Service core should keep its bottom body edge")
	var service_top_right_atlas: Vector2i = wall_layer.get_cell_atlas_coords(Vector2i(2, 0))
	var service_bottom_right_atlas: Vector2i = wall_layer.get_cell_atlas_coords(Vector2i(2, 3))
	assert_false(service_top_right_atlas == tilemap.get("body_top_right_corner_tile"), "Service top-right should use a top edge tile, not a removed right-corner tile: actual=%s corner=%s edges=%s" % [str(service_top_right_atlas), str(tilemap.get("body_top_right_corner_tile")), str(tilemap.get("body_top_edge_tiles"))])
	assert_false(service_bottom_right_atlas == tilemap.get("body_bottom_right_corner_tile"), "Service bottom-right should use a bottom edge tile, not a removed right-corner tile: actual=%s corner=%s edges=%s" % [str(service_bottom_right_atlas), str(tilemap.get("body_bottom_right_corner_tile")), str(tilemap.get("body_bottom_edge_tiles"))])
	assert_eq(wall_layer.get_cell_source_id(Vector2i(2, 1)), -1, "Service core should not draw a right body wall next to the room")
	assert_eq(infrastructure_layer.get_cell_source_id(Vector2i(2, 1)), -1, "Service core should not paint a right-wall window when the right wall is disabled")
	tilemap.free()



	assert_true(room_shell_source.contains("room_pixel_size.x + ApartmentTileMap.TILE_SIZE * 0.5"), "Right-wall room doors should sit outside the room wall")
	assert_true(room_shell_source.contains("room_door.scale.x = -1.0"), "RoomShell should flip only the right-side 02 door instances")
	assert_true(room_source.contains("clip_contents = false"), "Room buttons should not clip outward-opening room doors")
	assert_true(service_scene.contains("TrafficRoot"), "FloorServiceCore should group route traffic nodes")
	assert_true(service_scene.contains("res://scenes/building/ExitDoor.tscn"), "FloorServiceCore should keep its legacy exit-door node hidden")
	assert_true(service_scene.contains("res://scenes/building/ElevatorDoor.tscn"), "FloorServiceCore should instance the elevator door scene")

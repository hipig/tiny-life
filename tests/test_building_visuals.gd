	assert_true(building_view_scene.contains("z_index = 20"), "TenantWorldLayer should render tenants in front of traffic doors during routes")
	assert_true(building_view_scene.contains("TenantRouteMarkers"), "BuildingView should expose editable tenant route markers")
	assert_true(building_view_scene.contains("LeftOffscreenMarker"), "BuildingView should expose a left offscreen marker for exit and entry routes")

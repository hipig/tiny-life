	var public_area_source := FileAccess.get_file_as_string("res://scripts/building/PublicAreaShell.gd")
	var floor_source := FileAccess.get_file_as_string("res://scripts/building/Floor.gd")
	var apartment_source := FileAccess.get_file_as_string("res://scripts/building/ApartmentBuilding.gd")
	var tilemap_source := FileAccess.get_file_as_string("res://scripts/building/ApartmentTileMap.gd")
	var building_view_scene := FileAccess.get_file_as_string("res://scenes/building/BuildingView.tscn")
	var building_view_source := FileAccess.get_file_as_string("res://scripts/building/BuildingView.gd")
	var ai_source := FileAccess.get_file_as_string("res://scripts/tenant/TenantAI.gd")
	var traffic_source := FileAccess.get_file_as_string("res://scripts/building/TrafficDoor.gd")
	var room_door_scene := FileAccess.get_file_as_string("res://scenes/building/RoomDoor.tscn")
	var exit_door_scene := FileAccess.get_file_as_string("res://scenes/building/ExitDoor.tscn")
	var elevator_door_scene := FileAccess.get_file_as_string("res://scenes/building/ElevatorDoor.tscn")
	var ai_config: Dictionary = economy.get("tenant_ai", {})
	assert_true(room_shell_scene.contains("res://scenes/building/RoomDoor.tscn"), "RoomShell should overlay a reusable room door scene")
	assert_true(room_shell_scene.contains("[node name=\"RoomDoor\""), "RoomShell should expose a RoomDoor child")
	assert_true(room_shell_source.contains("func get_room_door()"), "RoomShell should expose the room door to route scripts")
	assert_true(room_shell_source.contains("door_mirrored"), "RoomShell should support mirrored outward-opening room doors")
